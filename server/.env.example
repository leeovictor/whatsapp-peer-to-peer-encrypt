# Firebase Service Account (JSON content) — copie do Firebase Console:
# Project Settings > Service Accounts > Generate New Private Key
# Cole aqui todo o JSON em uma única linha.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"seu-projeto",...}

# Alternativa: caminho para o arquivo JSON da service account
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

# JWT Secret (opcional — default: 'dev-secret')
JWT_SECRET=meu-segredo-local

# Porta do servidor (opcional — default: 3001)
PORT=3001

# Data store: 'firestore' (produção) ou 'local' (desenvolvimento sem Firebase)
# DATA_STORE=local
